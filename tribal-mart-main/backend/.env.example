# ──────────────────────────────────────────────────────────
# Tribal Mart — backend environment template
# Copy this to backend/.env and fill in real values
# ──────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS) — must match the Vite dev server
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas (or local mongodb://localhost:27017/tribalmart)
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/tribalmart?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-strong-32-plus-char-secret-here
JWT_EXPIRE=7d

# Razorpay payment gateway (test keys are fine for demos)
# Get yours at https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# File upload limits
MAX_FILE_SIZE=5242880
