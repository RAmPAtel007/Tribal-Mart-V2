# ──────────────────────────────────────────────────────────
# Tribal Mart — frontend environment template
# Copy this to frontend/.env and fill in real values
# ──────────────────────────────────────────────────────────

# Backend API base URL
VITE_API_URL=http://localhost:5000

# Cloudinary — direct browser uploads
# Create a free account at https://cloudinary.com and an UNSIGNED upload
# preset under Settings → Upload → Upload presets. Make sure the preset
# allows the file types you need (images + pdf).
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_PRESET=your_unsigned_preset_name

# Google Gemini — powers the Saathi chatbot
# Get a free key at https://aistudio.google.com/apikey
# (Frontend-embedded key is fine for demos; move behind a backend
#  proxy for production.)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Vapi — voice AI assistant
# Dashboard → API Keys → copy the PUBLIC key (vapi_pub_...)
# Assistant ID is the UUID in the URL when editing your assistant.
# IMPORTANT: only the public key goes here. The private key must stay
# server-side; it grants admin-level access to your Vapi account.
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key
VITE_VAPI_ASSISTANT_ID=your_vapi_assistant_id
