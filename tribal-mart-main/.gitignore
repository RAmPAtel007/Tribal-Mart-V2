# ──────────────────────────────────────────────────────────
# Tribal Mart — .gitignore
# ──────────────────────────────────────────────────────────

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Build outputs
frontend/dist/
frontend/build/

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug-*.log
backend/debug-*.log

# Uploaded user files (keep folder structure via .gitkeep)
backend/uploads/avatars/*
backend/uploads/documents/*
backend/uploads/products/*
!backend/uploads/avatars/.gitkeep
!backend/uploads/documents/.gitkeep
!backend/uploads/products/.gitkeep

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Test coverage
coverage/

# Temporary scratch files
*_tmp.*
.cache/

